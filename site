<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Maf1kScripts</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
    --bg: #080808;
    --surface: #111111;
    --surface2: #1a1a1a;
    --border: rgba(255,255,255,0.07);
    --border-hover: rgba(255,255,255,0.15);
    --purple: #9b5cf6;
    --purple-dim: rgba(155,92,246,0.12);
    --purple-glow: rgba(155,92,246,0.25);
    --white: #ffffff;
    --gray: #666;
    --gray2: #333;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
    background: var(--bg);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

/* BACKGROUND GRID */
body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 40px 40px;
    z-index: 0;
}

/* PURPLE GLOW BG */
body::after {
    content: '';
    position: fixed;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(155,92,246,0.08) 0%, transparent 70%);
    z-index: 0;
    pointer-events: none;
}

/* WRAPPER */
.wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 460px;
    padding: 16px;
    animation: fadeUp 0.6s cubic-bezier(0.16,1,0.3,1) both;
}

@keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* TOP BAR */
.topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
    padding: 0 2px;
}

.logo {
    display: flex;
    align-items: center;
    gap: 10px;
}

.logo-mark {
    width: 32px;
    height: 32px;
    background: var(--white);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.logo-mark span {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 16px;
    color: #080808;
    line-height: 1;
}

.logo-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 18px;
    letter-spacing: -0.3px;
}

.badge {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 5px 12px;
    font-size: 11px;
    color: var(--gray);
    font-family: 'DM Mono', monospace;
}

.badge-dot {
    width: 6px;
    height: 6px;
    background: #4ade80;
    border-radius: 50%;
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
}

/* CARD */
.card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    transition: box-shadow 0.4s;
}

/* CARD HEADER */
.card-header {
    padding: 24px 24px 20px;
    border-bottom: 1px solid var(--border);
}

.card-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 22px;
    letter-spacing: -0.5px;
    margin-bottom: 4px;
}

.card-title span {
    color: var(--purple);
}

.card-sub {
    font-size: 13px;
    color: var(--gray);
}

/* TABS */
.tabs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
}

.tab-btn {
    padding: 9px 12px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--gray);
    cursor: pointer;
    font-size: 12px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    transition: all 0.2s;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.tab-btn:hover {
    border-color: var(--border-hover);
    color: var(--white);
    background: var(--surface2);
}

.tab-btn.active {
    background: var(--purple-dim);
    border-color: var(--purple);
    color: var(--purple);
    font-weight: 500;
}

/* SCRIPT AREA */
.script-area {
    padding: 20px 24px;
    border-bottom: 1px solid var(--border);
}

.script-label {
    font-size: 10px;
    font-family: 'DM Mono', monospace;
    color: var(--gray);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 10px;
}

.code-box {
    background: #0d0d0d;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    font-size: 11.5px;
    font-family: 'DM Mono', monospace;
    color: #ccc;
    word-break: break-all;
    line-height: 1.6;
    min-height: 64px;
    transition: border-color 0.3s;
}

/* COPY BUTTON */
.copy-btn {
    width: calc(100% - 48px);
    margin: 0 24px 20px;
    padding: 13px;
    border: none;
    border-radius: 12px;
    background: var(--white);
    color: #080808;
    font-weight: 700;
    font-size: 13px;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.1px;
}

.copy-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(255,255,255,0.12);
}

.copy-btn:active {
    transform: translateY(0);
}

.copy-btn.success {
    background: #4ade80;
    color: #052e16;
}

.copy-btn.purple-mode {
    background: var(--purple);
    color: white;
}

/* FOOTER */
.card-footer {
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--border);
}

.socials {
    display: flex;
    gap: 4px;
}

.social-link {
    display: flex;
    align-items: center;
    gap: 5px;
    color: var(--gray);
    text-decoration: none;
    font-size: 12px;
    padding: 6px 10px;
    border-radius: 8px;
    border: 1px solid transparent;
    transition: all 0.2s;
}

.social-link:hover {
    color: var(--white);
    border-color: var(--border);
    background: var(--surface2);
}

.copyright {
    font-size: 11px;
    color: var(--gray2);
    font-family: 'DM Mono', monospace;
}

/* ACTIVE TAB GLOW on card */
.card.glow-purple {
    box-shadow: 0 0 40px rgba(155,92,246,0.12);
}
</style>
</head>
<body>

<div class="wrapper">

    <!-- TOP BAR -->
    <div class="topbar">
        <div class="logo">
            <div class="logo-mark"><span>M</span></div>
            <span class="logo-name">Maf1kScripts</span>
        </div>
        <div class="badge">
            <div class="badge-dot"></div>
            <span id="counter">158</span> online
        </div>
    </div>

    <!-- CARD -->
    <div class="card glow-purple" id="card">

        <div class="card-header">
            <div class="card-title">Roblox <span>Script Hub</span></div>
            <div class="card-sub">Select a script below and copy to executor</div>
        </div>

        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab(1)">Trade Script</button>
            <button class="tab-btn" onclick="switchTab(2)">Auto Phantom Event</button>
            <button class="tab-btn" onclick="switchTab(3)">FireVsIce</button>
            <button class="tab-btn" onclick="switchTab(4)">Candy Esp Script [MINI GAME]</button>
        </div>

        <div class="script-area">
            <div class="script-label">Script</div>
            <div class="code-box" id="scriptBox"></div>
        </div>

        <button class="copy-btn purple-mode" id="copyBtn" onclick="copyScript()">Copy Script</button>

        <div class="card-footer">
            <div class="socials">
                <a href="https://www.youtube.com/@maf1k24" target="_blank" class="social-link">▶ YT</a>
                <a href="https://www.tiktok.com/@maf1k79" target="_blank" class="social-link">♪ TikTok</a>
            </div>
            <div class="copyright">© 2026</div>
        </div>

    </div>
</div>

<script>
const scripts = {
    1: 'loadstring(game:HttpGet("https://raw.githubusercontent.com/maf1k24/EtfbTradeScript/refs/heads/main/Loader.lua"))()',
    2: 'loadstring(game:HttpGet("https://raw.githubusercontent.com/maf1k24/AutoPhantomEvent/refs/heads/main/Loader.lua"))()',
    3: 'loadstring(game:HttpGet("https://raw.githubusercontent.com/maf1k24/FireVSIce/refs/heads/main/Loader.lua"))()',
    4: 'loadstring(game:HttpGet("https://raw.githubusercontent.com/maf1k24/CandyEspScript/refs/heads/main/Loader.lua"))()',
};

let currentTab = 1;
const scriptBox = document.getElementById("scriptBox");
const copyBtn   = document.getElementById("copyBtn");

function switchTab(tab) {
    currentTab = tab;
    document.querySelectorAll(".tab-btn").forEach((b, i) => {
        b.classList.toggle("active", i === tab - 1);
    });
    scriptBox.textContent = scripts[tab];
}

function copyScript() {
    navigator.clipboard.writeText(scripts[currentTab]).then(() => {
        copyBtn.textContent = "✓ Copied!";
        copyBtn.classList.remove("purple-mode");
        copyBtn.classList.add("success");
        setTimeout(() => {
            copyBtn.textContent = "Copy Script";
            copyBtn.classList.remove("success");
            copyBtn.classList.add("purple-mode");
        }, 1500);
    });
}

switchTab(1);

// Live counter
let current = 189;
setInterval(() => {
    current += Math.floor(Math.random() * 3) - 1;
    if (current < 170) current = 170;
    if (current > 220) current = 220;
    document.getElementById("counter").textContent = current;
}, 1000);
</script>
</body>
</html>
